{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "text": "idle" },
                "1": { "text": "active" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "gray", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "displayMode": "lcd",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "gpu_orchestrator_mode{job=\"gpu_orchestrator\", instance=~\"$instance\"}",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "title": "Orchestrator Mode",
      "type": "bargauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "gpu_serving_active_requests{job=\"gpu_serving\", instance=~\"$serving_instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "Serving Active Requests",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "gpu_serving_queue_depth{job=\"gpu_serving\", instance=~\"$serving_instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "Serving Queue Depth",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "gpu_learning_active{job=\"gpu_learning\"}",
          "legendFormat": "gpu{{gpu}} {{uuid}}",
          "refId": "A"
        }
      ],
      "title": "Learning Active",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (status) (rate(gpu_serving_requests_total{job=\"gpu_serving\", instance=~\"$serving_instance\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Serving Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, instance) (rate(gpu_serving_request_seconds_bucket{job=\"gpu_serving\", instance=~\"$serving_instance\"}[5m])))",
          "legendFormat": "p95 {{instance}}",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le, instance) (rate(gpu_serving_request_seconds_bucket{job=\"gpu_serving\", instance=~\"$serving_instance\"}[5m])))",
          "legendFormat": "p50 {{instance}}",
          "refId": "B"
        }
      ],
      "title": "Serving Latency",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (mode) (rate(gpu_learning_iterations_total{job=\"gpu_learning\"}[5m]))",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "title": "Learning Iteration Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "gpu_learning_last_iteration_seconds{job=\"gpu_learning\"}",
          "legendFormat": "{{mode}} gpu{{gpu}}",
          "refId": "A"
        }
      ],
      "title": "Learning Iteration Duration",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "gpu_orchestrator_observed_gpu_utilization_percent{job=\"gpu_orchestrator\", instance=~\"$instance\"}",
          "legendFormat": "util",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "gpu_orchestrator_observed_gpu_memory_percent{job=\"gpu_orchestrator\", instance=~\"$instance\"}",
          "legendFormat": "memory",
          "refId": "B"
        }
      ],
      "title": "Observed GPU Pressure",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (mode, reason) (rate(gpu_orchestrator_decisions_total{job=\"gpu_orchestrator\", instance=~\"$instance\"}[10m]))",
          "legendFormat": "{{mode}} :: {{reason}}",
          "refId": "A"
        }
      ],
      "title": "Orchestrator Decisions",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "includeAll": true,
        "label": "Orchestrator Instance",
        "multi": true,
        "name": "instance",
        "options": [],
        "query": "label_values(gpu_orchestrator_mode{job=\"gpu_orchestrator\"}, instance)",
        "refresh": 1,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "includeAll": true,
        "label": "Serving Instance",
        "multi": true,
        "name": "serving_instance",
        "options": [],
        "query": "label_values(gpu_serving_active_requests{job=\"gpu_serving\"}, instance)",
        "refresh": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "title": "GPU Lane Simulation",
  "uid": "gpu-lane-simulation",
  "version": 1
}
