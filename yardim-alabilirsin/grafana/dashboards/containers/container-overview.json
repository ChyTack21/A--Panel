{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(10, sum by (name) (rate(container_cpu_usage_seconds_total{job=\"cadvisor\", name!=\"\", image!=\"\", name=~\"$container\"}[5m])))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Top Containers by CPU",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(10, sum by (name) (container_memory_working_set_bytes{job=\"cadvisor\", name!=\"\", image!=\"\", name=~\"$container\"}))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Top Containers by Memory",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(10, sum by (name) (rate(container_network_receive_bytes_total{job=\"cadvisor\", name!=\"\", name=~\"$container\"}[5m])))",
          "legendFormat": "{{name}} rx",
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "topk(10, sum by (name) (rate(container_network_transmit_bytes_total{job=\"cadvisor\", name!=\"\", name=~\"$container\"}[5m])))",
          "legendFormat": "{{name}} tx",
          "refId": "B"
        }
      ],
      "title": "Container Network Throughput",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(10, sum by (name) (rate(container_fs_reads_bytes_total{job=\"cadvisor\", name!=\"\", name=~\"$container\"}[5m]) + rate(container_fs_writes_bytes_total{job=\"cadvisor\", name!=\"\", name=~\"$container\"}[5m])))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Container Filesystem IO",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "text": "DOWN" },
                "1": { "text": "UP" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 5,
      "options": {
        "displayMode": "lcd",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "up{job=~\"prometheus|node|cadvisor|gpu_demo|dcgm|gpu_fallback|http_probe\"}",
          "legendFormat": "{{job}} :: {{instance}}",
          "refId": "A"
        }
      ],
      "title": "Telemetry Target Health",
      "type": "bargauge"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "includeAll": true,
        "label": "Container",
        "multi": true,
        "name": "container",
        "options": [],
        "query": "label_values(container_cpu_usage_seconds_total{job=\"cadvisor\", name!=\"\", image!=\"\"}, name)",
        "refresh": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "title": "Container Overview",
  "uid": "container-overview",
  "version": 1
}
